{
  "name": "upos/audit-web-mcp",
  "description": "Standalone MCP server for Playwright-powered web audits.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "mcp/sdk": "^0.4",
    "symfony/process": "^6.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "AuditWebMcp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AuditWebMcp\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
