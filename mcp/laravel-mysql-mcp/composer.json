{
  "name": "upos/laravel-mysql-mcp",
  "description": "Standalone MCP server for Laravel + MySQL project introspection",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "mcp/sdk": "^0.4",
    "symfony/process": "^6.2"
  },
  "autoload": {
    "psr-4": {
      "LaravelMysqlMcp\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}