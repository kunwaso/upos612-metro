#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * CLI to report semantic code search index status (same as MCP tool index_status).
 * Run from repo root so MCP_SEMANTIC_* env defaults resolve correctly, or set env.
 *
 * Usage:
 *   php mcp/semantic-code-search-mcp/bin/index-status
 *
 * Exit: 0 if index is ready and not stale; non-zero otherwise.
 */

use SemanticCodeSearchMcp\Index\IndexRepository;

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);
ini_set('display_errors', '1');

$serverRoot = realpath(__DIR__ . '/..');
$workspaceRoot = getenv('MCP_SEMANTIC_WORKSPACE_ROOT');
if ($workspaceRoot === false || $workspaceRoot === '') {
    $workspaceRoot = realpath(__DIR__ . '/../../..');
} else {
    $workspaceRoot = realpath($workspaceRoot) ?: $workspaceRoot;
}

$indexRoot = getenv('MCP_SEMANTIC_INDEX_ROOT');
if ($indexRoot === false || $indexRoot === '') {
    $indexRoot = ($workspaceRoot !== false ? $workspaceRoot : realpath(__DIR__ . '/../../..')) . '/.cache/semantic-code-search-mcp';
} else {
    $indexRoot = realpath($indexRoot) ?: $indexRoot;
}

$model = getenv('MCP_SEMANTIC_EMBED_MODEL') ?: 'BAAI/bge-base-en';

if ($serverRoot === false || $workspaceRoot === false) {
    fwrite(STDERR, "Unable to resolve server or workspace root. Set MCP_SEMANTIC_WORKSPACE_ROOT if needed.\n");
    exit(1);
}

$autoload = $serverRoot . '/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Missing vendor/autoload.php. Run: cd mcp/semantic-code-search-mcp && composer install\n");
    exit(1);
}

require_once $autoload;

$normalizedWorkspaceRoot = str_replace('\\', '/', $workspaceRoot);
$indexPath = rtrim(str_replace('\\', '/', $indexRoot), '/') . '/semantic-code-search.sqlite';

try {
    $repository = new IndexRepository($indexPath);
    $status = $repository->status($normalizedWorkspaceRoot, $model);
} catch (Throwable $e) {
    fwrite(STDERR, "Error: " . $e->getMessage() . "\n");
    fwrite(STDERR, "Index not ready. Run index-codebase first.\n");
    exit(1);
}

$ready = $status['ready'];
$stale = $status['stale'];

echo "Index path:      " . $status['index_path'] . "\n";
echo "Workspace root:  " . ($status['workspace_root'] ?? '(none)') . "\n";
echo "Model:           " . ($status['model'] ?? '(none)') . "\n";
echo "Last indexed:    " . ($status['last_indexed_at'] ?? '(never)') . "\n";
echo "Files indexed:   " . $status['files_indexed'] . "\n";
echo "Chunks indexed:  " . $status['chunks_indexed'] . "\n";
echo "Ready:           " . ($ready ? 'yes' : 'no') . "\n";
echo "Stale:           " . ($stale ? 'yes' : 'no') . "\n";

if (!$ready) {
    echo "\nIndex not ready. Run index-codebase first.\n";
    exit(1);
}

if ($stale) {
    echo "\nIndex is stale (workspace or model changed). Re-run index-codebase.\n";
    exit(1);
}

echo "\nSemantic index is ready.\n";
exit(0);
