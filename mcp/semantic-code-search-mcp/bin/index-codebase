#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * CLI to build the semantic code search index (same as MCP tool index_codebase).
 * Run from repo root so MCP_SEMANTIC_* env defaults resolve correctly, or set env.
 *
 * Usage:
 *   php mcp/semantic-code-search-mcp/bin/index-codebase
 *   php mcp/semantic-code-search-mcp/bin/index-codebase --force
 */

use SemanticCodeSearchMcp\Embeddings\EmbedderFactory;
use SemanticCodeSearchMcp\Index\Chunker;
use SemanticCodeSearchMcp\Index\FileDiscovery;
use SemanticCodeSearchMcp\Index\Indexer;
use SemanticCodeSearchMcp\Index\IndexRepository;
use SemanticCodeSearchMcp\PathGuard;

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);
ini_set('display_errors', '1');

$serverRoot = realpath(__DIR__.'/..');
$workspaceRoot = getenv('MCP_SEMANTIC_WORKSPACE_ROOT') ?: realpath(__DIR__.'/../../..');
$indexRoot = getenv('MCP_SEMANTIC_INDEX_ROOT');
if ($indexRoot === false || $indexRoot === '') {
    $indexRoot = ($workspaceRoot !== false ? $workspaceRoot : realpath(__DIR__.'/../../..')).'/.cache/semantic-code-search-mcp';
} else {
    $indexRoot = realpath($indexRoot) ?: $indexRoot;
}

if ($serverRoot === false || $workspaceRoot === false) {
    fwrite(STDERR, "Unable to resolve server or workspace root. Set MCP_SEMANTIC_WORKSPACE_ROOT if needed.\n");
    exit(1);
}

$autoload = $serverRoot.'/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Missing vendor/autoload.php. Run: cd mcp/semantic-code-search-mcp && composer install\n");
    exit(1);
}

require_once $autoload;

$force = in_array('--force', $argv ?? [], true);

$readPositiveInt = static function (string $name, int $default): int {
    $raw = getenv($name);
    if ($raw === false || $raw === '') {
        return $default;
    }

    $value = filter_var($raw, FILTER_VALIDATE_INT);

    return ($value !== false && $value >= 1) ? $value : $default;
};

$maxFileBytes = $readPositiveInt('MCP_SEMANTIC_MAX_FILE_BYTES', 2097152);
$chunkLines = $readPositiveInt('MCP_SEMANTIC_CHUNK_LINES', 60);
$chunkOverlap = $readPositiveInt('MCP_SEMANTIC_CHUNK_OVERLAP', 15);
$model = EmbedderFactory::modelFromEnvironment();
$normalizedWorkspaceRoot = str_replace('\\', '/', $workspaceRoot);

$pathGuard = new PathGuard($workspaceRoot);
$discovery = new FileDiscovery($pathGuard, $maxFileBytes);
$chunker = new Chunker($chunkLines, min($chunkOverlap, max(0, $chunkLines - 1)));
$indexPath = rtrim(str_replace('\\', '/', $indexRoot), '/').'/semantic-code-search.sqlite';
$repository = new IndexRepository($indexPath);
$embedder = EmbedderFactory::fromEnvironment($serverRoot);

$indexer = new Indexer($discovery, $chunker, $repository, $embedder, $normalizedWorkspaceRoot);

echo "Workspace: {$normalizedWorkspaceRoot}\n";
echo "Index:     {$indexPath}\n";
echo "Model:     {$model}\n";
echo 'Force:     '.($force ? 'yes' : 'no')."\n";
echo "Indexing...\n";

try {
    $result = $indexer->index(null, $force);
} catch (Throwable $e) {
    fwrite(STDERR, 'Index failed: '.$e->getMessage()."\n");
    exit(1);
}

echo sprintf(
    "Done. Indexed %d files, %d chunks written (%d scanned, %d removed).\n",
    $result['files_indexed'],
    $result['chunks_written'],
    $result['files_scanned'],
    $result['files_removed']
);

