# Copy to `.env` in this directory (mcp/mcp-cyber). Do not commit `.env`.

# --- PostgreSQL (async driver for FastAPI) ---
# Use CYBER_DATABASE_URL or the same value as Laravel-style DATABASE_URL
CYBER_DATABASE_URL=postgresql+asyncpg://postgres:admin@127.0.0.1:5432/cyber

# Alembic / sync migrations (optional; postgres:// is rewritten to psycopg3 in env.py)
CYBER_DATABASE_URL_SYNC=postgres://postgres:admin@127.0.0.1:5432/cyber

# --- API bind (match MCP client URL host/port) ---
CYBER_LISTEN_HOST=127.0.0.1
CYBER_LISTEN_PORT=8686

# Dev: auto-reload on code changes
CYBER_RELOAD=true

# Dev UI at http://127.0.0.1:8686/ — scans + scan_events + audit (no JWT). Set false if API is exposed.
# CYBER_DASHBOARD_ENABLED=false

# Policy file (absolute path recommended on Windows)
# CYBER_POLICY_PATH=D:/wamp64/www/upos612/mcp/mcp-cyber/configs/default.policy.yaml

# JWT signing (change in any shared environment)
# CYBER_DEV_SECRET=your-secret

# --- MCP client (Cursor / CLI) — same values in mcp.json `env` ---
# The API does not read these; they are for documentation / copy-paste.
CYBER_API_URL=http://127.0.0.1:8686
# CYBER_API_TOKEN=<paste output of: python scripts/seed_demo.py>

# One-command passive scan of a live site you control (after API + token are set):
#   python scripts/quick_scan_remote.py --base-url https://plm.pekofactory.store/

# --- Phase 2: OIDC (optional; when all three are set, API validates RS256/ES256 via JWKS first) ---
# CYBER_OIDC_ISSUER=https://your-idp/realms/your-realm
# CYBER_OIDC_AUDIENCE=mcp-cyber
# CYBER_OIDC_JWKS_URL=https://your-idp/realms/your-realm/protocol/openid-connect/certs
# CYBER_OIDC_DEFAULT_ORG_ID=00000000-0000-4000-8000-000000000001
# CYBER_AUTH_DEV_JWT_ALONGSIDE_OIDC=false   # set false in prod when OIDC is on

# --- Phase 2: Vault refs for ScanProfile.credential_ref (worker only; never pass secrets in API body) ---
# CYBER_VAULT_JSON={"my-login":{"username":"u","password":"p"}}   # dev only
# CYBER_VAULT_FILE=/path/to/secrets.json
# VAULT_ADDR=  VAULT_TOKEN=  CYBER_VAULT_KV_MOUNT=secret

# --- Phase 2: Playwright browser login (password flows) ---
# CYBER_PLAYWRIGHT_ADAPTER=1
# pip install -e ".[phase2]" && playwright install chromium

# --- Phase 2: Evidence files (screenshots) ---
# CYBER_EVIDENCE_DIR=./data/evidence

# --- Phase 3: Redis scan queue (optional; install pip install -e ".[phase3]") ---
# When set, POST /v1/scans LPUSHes the run id; run worker: python -m cyber_worker.consumer
# or: mcp-cyber-scan-worker
# CYBER_REDIS_URL=redis://127.0.0.1:6379/0
# Docker: docker compose --profile ha-scans up scan-worker (and set CYBER_REDIS_URL on api)

# --- Phase 4: analytics / SLA (optional) ---
# CYBER_SLA_HIGH_CRITICAL_DAYS=14
# CYBER_ANALYTICS_MAX_TREND_DAYS=90

# --- Phase 5: business rules + fuzz stub hook (optional) ---
# YAML applied after adapters, before normalize (tag enrichment only). See configs/business_rules.sample.yaml
# CYBER_BUSINESS_RULES_PATH=configs/business_rules.sample.yaml
# Set to 1 to allow fuzz_harness_stub adapter to emit its info finding when the adapter is on the profile:
# CYBER_FUZZ_STUB_ENABLED=0
