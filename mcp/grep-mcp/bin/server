#!/usr/bin/env php
<?php

declare(strict_types=1);

use GrepMcp\GrepTool;
use GrepMcp\PathGuard;
use Mcp\Server;
use Mcp\Server\Transport\StdioTransport;

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);
ini_set('display_errors', '0');

$serverRoot = realpath(__DIR__.'/..');
$workspaceRoot = getenv('MCP_GREP_WORKSPACE_ROOT') ?: realpath(__DIR__.'/../../..');

if ($serverRoot === false || $workspaceRoot === false) {
    fwrite(STDERR, "Unable to resolve server or workspace root.\n");
    exit(1);
}

$autoload = $serverRoot.'/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Missing vendor/autoload.php. Run composer install in mcp/grep-mcp.\n");
    exit(1);
}

require_once $autoload;

try {
    $readPositiveInt = static function (string $name, int $default): int {
        $raw = getenv($name);
        if ($raw === false || $raw === '') {
            return $default;
        }

        $value = filter_var($raw, FILTER_VALIDATE_INT);
        if ($value === false || $value < 1) {
            throw new RuntimeException(sprintf('%s must be a positive integer.', $name));
        }

        return $value;
    };

    $defaultMaxCount = $readPositiveInt('MCP_GREP_MAX_COUNT', 200);
    $timeoutSeconds = $readPositiveInt('MCP_GREP_TIMEOUT_SECONDS', 30);

    $pathGuard = new PathGuard($workspaceRoot);
    $tool = new GrepTool($pathGuard, $defaultMaxCount, $timeoutSeconds);

    $builder = Server::builder()
        ->setServerInfo('grep', '1.0.0', 'Standalone MCP server for guarded repo-wide ripgrep search.')
        ->setInstructions('Use grep for repo-wide regex or fixed-string pattern search inside the workspace.')
        ->setPaginationLimit(50);

    $integer = static fn (): array => ['type' => 'integer'];
    $boolean = static fn (): array => ['type' => 'boolean'];
    $string = static fn (): array => ['type' => 'string'];

    $builder->addTool($tool->grep(...), 'grep', 'Search the workspace with ripgrep and return guarded structured matches.', inputSchema: [
        'type' => 'object',
        'properties' => [
            'pattern' => [
                'type' => 'string',
                'description' => 'Required regex or literal pattern to search for.',
            ],
            'path' => [
                'type' => 'string',
                'description' => 'Optional relative path from workspace root, or absolute path inside workspace, to narrow the search.',
            ],
            'include_glob' => [
                'type' => 'string',
                'description' => 'Optional ripgrep glob include filter such as *.php.',
            ],
            'exclude_glob' => [
                'type' => 'string',
                'description' => 'Optional ripgrep glob exclude filter such as vendor/**.',
            ],
            'max_count' => [
                'type' => 'integer',
                'minimum' => 1,
                'description' => 'Maximum number of matches returned. Values above 500 are clamped.',
            ],
            'fixed_strings' => [
                'type' => 'boolean',
                'description' => 'Treat the pattern as a literal string instead of a regular expression.',
            ],
            'ignore_case' => [
                'type' => 'boolean',
                'description' => 'Match case-insensitively (same as ripgrep -i).',
            ],
            'max_depth' => [
                'type' => 'integer',
                'minimum' => 1,
                'maximum' => 100,
                'description' => 'Optional maximum directory traversal depth (same as ripgrep --max-depth).',
            ],
            'smart_case' => [
                'type' => 'boolean',
                'description' => 'Enable smart case: when pattern has no uppercase letters, search case-insensitively.',
            ],
        ],
        'required' => ['pattern'],
        'additionalProperties' => false,
    ], outputSchema: [
        'type' => 'object',
        'properties' => [
            'matches' => [
                'type' => 'array',
                'items' => [
                    'type' => 'object',
                    'properties' => [
                        'file' => $string(),
                        'line' => $integer(),
                        'column' => $integer(),
                        'match' => $string(),
                    ],
                    'required' => ['file', 'line', 'column', 'match'],
                    'additionalProperties' => false,
                ],
            ],
            'total_count' => $integer(),
            'truncated' => $boolean(),
        ],
        'required' => ['matches', 'total_count', 'truncated'],
        'additionalProperties' => false,
    ]);

    $server = $builder->build();
    $transport = new StdioTransport(STDIN, STDOUT);
    $server->run($transport);
} catch (Throwable $exception) {
    fwrite(STDERR, sprintf("MCP server fatal error: %s\n", $exception->getMessage()));
    exit(1);
}
