{
  "mcpServers": {
    "laravel_mysql": {
      "command": "php",
      "args": ["D:/wamp64/www/upos612/mcp/laravel-mysql-mcp/bin/server"]
    },
    "grep": {
      "command": "php",
      "args": ["D:/wamp64/www/upos612/mcp/grep-mcp/bin/server"],
      "env": {
        "MCP_GREP_WORKSPACE_ROOT": "D:/wamp64/www/upos612"
      }
    },
    "read_file_cache": {
      "command": "php",
      "args": ["D:/wamp64/www/upos612/mcp/read-file-cache-mcp/bin/server"],
      "env": {
        "MCP_READ_FILE_WORKSPACE_ROOT": "D:/wamp64/www/upos612",
        "MCP_READ_FILE_CACHE_ROOT": "D:/wamp64/www/upos612/.cache/read-file-cache-mcp"
      }
    },
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus@1.4.8", "mcp"]
    },
    "semantic_code_search": {
      "command": "php",
      "args": ["D:/wamp64/www/upos612/mcp/semantic-code-search-mcp/bin/server"],
      "env": {
        "MCP_SEMANTIC_WORKSPACE_ROOT": "D:/wamp64/www/upos612",
        "MCP_SEMANTIC_INDEX_ROOT": "D:/wamp64/www/upos612/.cache/semantic-code-search-mcp",
        "MCP_SEMANTIC_EMBED_BACKEND": "huggingface",
        "MCP_SEMANTIC_EMBED_MODEL": "BAAI/bge-small-en",
        "MCP_SEMANTIC_HF_DEVICE": "cpu",
        "MCP_SEMANTIC_HF_BATCH_SIZE": "12",
        "MCP_SEMANTIC_HF_LOCAL_FILES_ONLY": "1",
        "MCP_SEMANTIC_CHUNK_LINES": "80",
        "MCP_SEMANTIC_CHUNK_OVERLAP": "8",
        "MCP_SEMANTIC_INCLUDE_ROOTS": "app,Modules,routes,resources/views,config,ai,mcp,.cursor",
        "MCP_SEMANTIC_INCLUDE_ROOT_FILES": "AGENTS.md,AGENTS-FAST.md,composer.json,composer.lock,README.md,modules_statuses.json"
      }
    },
    "env": {
  "CYBER_API_URL": "http://127.0.0.1:8686",
  "CYBER_API_TOKEN": "<JWT from seed_demo.py>"
}
  }
}
